import heapq
import os


class HuffmanNode:
    def __init__(self, char, freq):
        self.char = char
        self.freq = freq
        self.left = None
        self.right = None

    def __lt__(self, other):
        return self.freq < other.freq

class FileZipper:
    def __init__(self):
        self.codes = {}
        self.reverse_codes = {}

    def _build_frequency_map(self, data):
        frequency = {}
        for char in data:
            frequency[char] = frequency.get(char, 0) + 1
        return frequency

    def _build_huffman_tree(self, frequency):
        heap = []
        for key, value in frequency.items():
            node = HuffmanNode(key, value)
            heapq.heappush(heap, node)

        while len(heap) > 1:
            node1 = heapq.heappop(heap)
            node2 = heapq.heappop(heap)

            merged = HuffmanNode(None, node1.freq + node2.freq)
            merged.left = node1
            merged.right = node2

            heapq.heappush(heap, merged)

        # FIXED HERE: Added [0] to return the actual root node object
        return heap[0] if heap else None

    def _build_codes_helper(self, root, current_code):
        if root is None:
            return

        if root.char is not None:
            self.codes[root.char] = current_code
            self.reverse_codes[current_code] = root.char
            return

        self._build_codes_helper(root.left, current_code + "0")
        self._build_codes_helper(root.right, current_code + "1")

    def _build_codes(self, root):
        self.codes = {}
        self.reverse_codes = {}
        self._build_codes_helper(root, "")

    def _get_encoded_string(self, data):
        encoded_text = ""
        for char in data:
            encoded_text += self.codes[char]
        return encoded_text

    def _pad_encoded_string(self, encoded_text):
        extra_padding = 8 - (len(encoded_text) % 8)
        for i in range(extra_padding):
            encoded_text += "0"

        padded_info = "{0:08b}".format(extra_padding)
        encoded_text = padded_info + encoded_text
        return encoded_text

    def _get_byte_array(self, padded_encoded_text):
        b = bytearray()
        for i in range(0, len(padded_encoded_text), 8):
            byte = padded_encoded_text[i:i+8]
            b.append(int(byte, 2))
        return b

    def zip_file(self, input_path, output_path):
        if not os.path.exists(input_path):
            print(f"Error: File {input_path} not found.")
            return

        with open(input_path, 'rb') as file:
            data = file.read()

        if len(data) == 0:
            print("Error: Input file is empty.")
            return

        frequency = self._build_frequency_map(data)
        root = self._build_huffman_tree(frequency)
        self._build_codes(root)

        encoded_text = self._get_encoded_string(data)
        padded_text = self._pad_encoded_string(encoded_text)
        final_bytes = self._get_byte_array(padded_text)

        with open(output_path, 'wb') as output_file:
            pickle.dump(frequency, output_file)
            output_file.write(final_bytes)
       
        print(f"Success! Compressed file saved to: {output_path}")

    def _remove_padding(self, padded_encoded_text):
        padded_info = padded_encoded_text[:8]
        extra_padding = int(padded_info, 2)

        padded_encoded_text = padded_encoded_text[8:]
        encoded_text = padded_encoded_text[:-1*extra_padding]

        return encoded_text

    def _decode_string(self, encoded_text):
        current_code = ""
        decoded_bytes = bytearray()

        for bit in encoded_text:
            current_code += bit
            if current_code in self.reverse_codes:
                character = self.reverse_codes[current_code]
                decoded_bytes.append(character)
                current_code = ""

        return decoded_bytes

    def unzip_file(self, input_path, output_path):
        if not os.path.exists(input_path):
            print(f"Error: File {input_path} not found.")
            return

        with open(input_path, 'rb') as file:
            frequency = pickle.load(file)
            remaining_bytes = file.read()

        root = self._build_huffman_tree(frequency)
        self._build_codes(root)

        bit_string = ""
        for byte in remaining_bytes:
            bit_string += "{0:08b}".format(byte)

        encoded_text = self._remove_padding(bit_string)
        decompressed_data = self._decode_string(encoded_text)

        with open(output_path, 'wb') as output_file:
            output_file.write(decompressed_data)
           
        print(f"Success! Unzipped file saved to: {output_path}")

