import java.util.Scanner;

public class Main {
    public static void main(String[] args) {
        Scanner sc = new Scanner(System.in);
        
        if (sc.hasNextInt()) {
            int t = sc.nextInt(); 
            while (t-- > 0) {
                int n = sc.nextInt(); 
                int count = 0;
                int currentNumber = 1;
                while (count < n) {
                    if (currentNumber % 3 != 0) {
                        System.out.print(currentNumber + " ");
                        count++;
                    }
                    currentNumber++;
                }
                System.out.println(); 
            }
        }
        sc.close();
    }
}
